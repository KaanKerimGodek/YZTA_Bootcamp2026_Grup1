# ===========================================================================
# Vazgeçtim — Environment configuration
# ===========================================================================
# Kopyala:  copy .env.example .env   (Windows)   |   cp .env.example .env
# Doldurduktan sonra gerçek değerleri gir.
# ---------------------------------------------------------------------------

# Backend modu. "mock" → demo verisiyle çalışır (backend gerektirmez).
#                  "live"  → n8n webhook + Supabase ile konuşur.
APP_MODE=mock

# n8n orkestrasyon webhook URL'i (Workflow 1 — Kayıt & Kategorizasyon).
# n8n içindeki webhook node'unun "Production URL" / "Test URL" değerini yapıştır.
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/vazgec-ekle

# Webhook çağrılarında gönderilen sabit kullanıcı tanımlayıcısı (demo amaçlı).
# Üretimde auth (Supabase Auth) ile değiştirilecek.
USER_ID=00000000-0000-0000-0000-000000000000

# --- Supabase (APP_MODE=live için opsiyonel doğrudan erişim) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- n8n → LLM (Workflow içinden ayarlanır, burada yalnızca referans) ---
# LLM_PROVIDER=gemini_flash   (maliyet optimizasyonu için önerilen)
